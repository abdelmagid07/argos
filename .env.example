# Copy to .env (gitignored) and fill in as needed.
# Every variable is optional; the defaults run end-to-end on SQLite + the
# in-memory feature store.

# --- Offline store --------------------------------------------------------
# Leave empty to use local SQLite at ./argos.db.
# For Postgres / Supabase, paste the pooler URL (port 6543).
DATABASE_URL=

# --- Online feature store -------------------------------------------------
# Leave empty to use the in-memory store (loaded from DB at API startup).
# Enable Redis with:  docker compose up -d redis
# Compose maps the container's 6379 -> host 6380.
REDIS_URL=

# --- Streaming ingest (Kafka) ---------------------------------------------
# Defaults match `docker compose up -d zookeeper kafka`.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_DLQ_TOPIC=transactions-dlq
KAFKA_GROUP_ID=postgres-sink
